{
  "compilerOptions": {
    "strict": true,
    // Entity and injected fields are populated by TypeORM/Nest, not a constructor.
    "strictPropertyInitialization": false,
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    // Inside outDir: a buildinfo outliving a deleted dist makes tsc skip emit.
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "skipLibCheck": true,
    "types": ["node", "jest"]
  }
}
